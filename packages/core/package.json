    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/node": "25.9.1",
    "tsdown": "0.22.1",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
