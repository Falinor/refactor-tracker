    "migration",
    "progress",
    "refactor",
    "refactoring",
    "tech-debt",
    "technical-debt"
  ],
  "homepage": "https://github.com/Falinor/refactor-tracker/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/Falinor/refactor-tracker/issues"
  },
  "license": "Apache-2.0",
  "author": "Andrea Gueugnaut",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Falinor/refactor-tracker.git",
    "directory": "packages/core"
  },
  "bin": {
    "refactor-tracker": "dist/cli.js"
  },
  "files": [
