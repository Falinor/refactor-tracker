{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "reporters": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          }
        },
        "required": ["type"],
        "additionalProperties": {}
      }
    },
    "refactors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "registeredAt": {
            "type": "string",
            "anyOf": [
              {
                "format": "date"
              },
              {
                "format": "date-time"
              }
            ],
            "description": "ISO-8601 date (YYYY-MM-DD) or full timestamp; recorded when the refactor was registered."
          },
          "detect": {
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "command": {
                    "type": "string"
                  },
                  "binary": {
                    "type": "boolean",
                    "const": true
                  }
                },
                "required": ["command", "binary"],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "done": {
                    "type": "object",
                    "properties": {
                      "command": {
                        "type": "string"
                      }
                    },
                    "required": ["command"],
                    "additionalProperties": false
                  },
                  "remaining": {
                    "type": "object",
                    "properties": {
                      "command": {
                        "type": "string"
                      }
                    },
                    "required": ["command"],
                    "additionalProperties": false
                  },
                  "total": {
                    "type": "object",
                    "properties": {
                      "command": {
                        "type": "string"
                      }
                    },
                    "required": ["command"],
                    "additionalProperties": false
                  },
                  "list": {
                    "type": "object",
                    "properties": {
                      "command": {
                        "type": "string"
                      }
                    },
                    "required": ["command"],
                    "additionalProperties": false
                  }
                },
                "additionalProperties": false
              }
            ]
          }
        },
        "required": ["id", "name", "detect"],
        "additionalProperties": false
      }
    }
  },
  "required": ["refactors"],
  "additionalProperties": false,
  "$id": "https://raw.githubusercontent.com/Falinor/refactor-tracker/main/packages/core/schema.json",
  "title": "refactor-tracker config",
  "description": "Schema for refactor-tracker YAML config files (typically .refactor-tracker.yml)."
}
