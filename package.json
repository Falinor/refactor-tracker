{
  "name": "refactor-tracker-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "pnpm -r --parallel build",
    "test": "pnpm -r test",
    "dev": "pnpm --filter refactor-tracker dev",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,mts,cts}": [
      "oxfmt",
      "oxlint --fix"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
